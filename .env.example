APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Frete: stub (padrão) ou melhorenvio
SHIPPING_DRIVER=stub
# Token estático (fluxo "conta única"). Deixe vazio se usar OAuth abaixo.
MELHORENVIO_TOKEN=
# O ambiente (sandbox/produção) se configura pela tela Configurações → Pagamento/Frete.
MELHORENVIO_CEP_ORIGEM=01001000
# OAuth2 (lojista conecta a própria conta ME pelo painel).
# As credenciais do app (client_id/secret, um app POR AMBIENTE) se configuram pela
# tela Configurações → Pagamento/Frete; os envs abaixo são só fallback (modelo
# "plataforma configura por env"). A URL de redirecionamento é derivada de APP_URL —
# MELHORENVIO_REDIRECT_URI sobrepõe (útil com túnel ngrok em dev).
MELHORENVIO_CLIENT_ID=
MELHORENVIO_CLIENT_SECRET=
MELHORENVIO_REDIRECT_URI=
# Obrigatório pelo ME: identifica app + e-mail de contato.
MELHORENVIO_USER_AGENT="Pontto (contato@seudominio.com.br)"

# Pagamento: driver ativo e token da conta Yapay agora se configuram pela tela
# Configurações → Integrações no painel (não mais aqui).
#
# Autentica a URL de notificação do webhook (?wh_secret=...), independente do
# driver. OBRIGATÓRIO em produção — sem ele o webhook rejeita tudo (fail-closed).
# Gere com: php artisan tinker --execute="echo Str::random(40);"
PAYMENT_WEBHOOK_SECRET=
# Mercado Pago: access token E secret do webhook (x-signature) se configuram pela
# tela (Configurações → Pagamento/Frete). O env abaixo é só fallback do secret.
MERCADOPAGO_WEBHOOK_SECRET=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# URL do storefront (Remix) usada nos links de e-mail (reset de senha etc.)
STOREFRONT_URL=http://localhost:3000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
